{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecureVault AI",
  "version": "0.1.0",
  "identifier": "ai.securevault.desktop",
  "build": {
    "beforeBuildCommand": "npm run build:desktop-web",
    "beforeDevCommand": "npm run build:desktop-web",
    "frontendDist": "../out"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": [
      "../local-vault-api/app",
      "../local-vault-api/run_local_vault_api.py"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "SecureVault AI",
        "width": 1280,
        "height": 860,
        "resizable": true
      }
    ]
  }
}
